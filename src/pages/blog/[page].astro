---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PostList from '../../components/PostList.astro';
import PostPagination from '../../components/PostPagination.astro';
import TagFilter from '../../components/TagFilter.astro';
import { getAllTags, getPageSlice, getPublishedPosts, totalPages } from '../../lib/posts';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const total = totalPages(posts);
	const tags = getAllTags(posts);

	if (total <= 1) return [];

	return Array.from({ length: total - 1 }, (_, i) => {
		const pageNumber = i + 2;
		return {
			params: { page: String(pageNumber) },
			props: { posts: getPageSlice(posts, pageNumber), tags, totalPages: total }
		};
	});
}

const pageNumber = Number(Astro.params.page);
const { posts, tags, totalPages: total } = Astro.props;
---

<SiteLayout title={`Page ${pageNumber} · jz's Blog`} description="Blog archive">
	<TagFilter tags={tags} />
	<PostList posts={posts} ariaLabel={`Posts page ${pageNumber}`} />
	<PostPagination pageNumber={pageNumber} totalPages={total} firstHref="/" pagePrefix="/blog/" />
</SiteLayout>
