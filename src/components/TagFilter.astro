---
import { getTagHref } from '../lib/posts';

interface Props {
	tags: string[];
	activeTag?: string;
}

const { tags, activeTag } = Astro.props;
const allActive = activeTag === undefined;
---

<nav class="tag-filter" aria-label="Filter posts by tag">
	<a
		class:list={['tag-filter__item', 'tag-filter__item--all', { active: allActive }]}
		href="/"
		aria-current={allActive ? 'page' : undefined}
	>
		all
	</a>
	{tags.map((tag) => (
		<a
			class:list={['tag-filter__item', { active: activeTag === tag }]}
			href={getTagHref(tag)}
			data-tag={tag}
			aria-current={activeTag === tag ? 'page' : undefined}
		>
			{tag}
		</a>
	))}
</nav>

<style>
	.tag-filter {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin: 0 0 1.5rem;
	}
	.tag-filter__item {
		display: inline-flex;
		align-items: center;
		min-height: 1.45rem;
		padding: 0.18rem 0.48rem;
		border-radius: 10px;
		border: 1px solid #d1d5db;
		background: #f3f4f6;
		color: #374151;
		font-size: 0.9rem;
		line-height: 1;
		text-decoration: none;
	}
	.tag-filter__item[data-tag='intro'] {
		border-color: #fecdd3;
		background: #ffe4e6;
		color: #be123c;
	}
	.tag-filter__item[data-tag='life'] {
		border-color: #fed7aa;
		background: #ffedd5;
		color: #c2410c;
	}
	.tag-filter__item[data-tag='science'] {
		border-color: #fde68a;
		background: #fef3c7;
		color: #b45309;
	}
	.tag-filter__item[data-tag='fiction'] {
		border-color: #ded6ff;
		background: #f1edff;
		color: #6b5ca5;
	}
	.tag-filter__item.active {
		background: #374151;
		border-color: #374151;
		color: #f9fafb;
	}
	.tag-filter__item[data-tag='intro'].active {
		background: #be123c;
		border-color: #be123c;
		color: #fff1f2;
	}
	.tag-filter__item[data-tag='life'].active {
		background: #c2410c;
		border-color: #c2410c;
		color: #fff7ed;
	}
	.tag-filter__item[data-tag='science'].active {
		background: #b45309;
		border-color: #b45309;
		color: #fffbeb;
	}
	.tag-filter__item[data-tag='fiction'].active {
		background: #6b5ca5;
		border-color: #6b5ca5;
		color: #f8f6ff;
	}
	.tag-filter__item:hover {
		text-decoration: none;
		border-color: #6b7280;
	}
	.tag-filter__item[data-tag='intro']:hover {
		border-color: #e11d48;
	}
	.tag-filter__item[data-tag='life']:hover {
		border-color: #ea580c;
	}
	.tag-filter__item[data-tag='science']:hover {
		border-color: #d97706;
	}
	.tag-filter__item[data-tag='fiction']:hover {
		border-color: #8877c5;
	}
</style>
