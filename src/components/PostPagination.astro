---
interface Props {
	pageNumber: number;
	totalPages: number;
	firstHref: string;
	pagePrefix: string;
}

const { pageNumber, totalPages, firstHref, pagePrefix } = Astro.props as Props;
const prevPage = pageNumber > 1 ? pageNumber - 1 : null;
const nextPage = pageNumber < totalPages ? pageNumber + 1 : null;
const hrefForPage = (page: number) => (page === 1 ? firstHref : `${pagePrefix}${page}/`);
---

{totalPages > 1 && (
	<nav class="pagination" aria-label="Pagination">
		{prevPage ? (
			<a class="page-link" href={hrefForPage(prevPage)}>
				← Previous
			</a>
		) : (
			<span aria-hidden="true"></span>
		)}
		<p>Page {pageNumber} of {totalPages}</p>
		{nextPage ? (
			<a class="page-link" href={hrefForPage(nextPage)}>
				Next →
			</a>
		) : (
			<span aria-hidden="true"></span>
		)}
	</nav>
)}

<style>
	.pagination {
		margin-top: 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
		color: #475569;
	}
	.pagination p {
		margin: 0;
	}
	.page-link {
		color: #334155;
		font-weight: 600;
	}
	.page-link:hover {
		color: #0f172a;
	}
	@media (max-width: 680px) {
		.pagination {
			flex-wrap: wrap;
		}
	}
</style>
